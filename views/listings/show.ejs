    </svg>
                                    <span>

                                        Reviews
                                    </span>
                                </p>
                                <p class="card-text">
                                    <%= listing.reviews.length %>
                                </p>
                            </div>
                            <div class="vr"></div>
                            <div class="info-block">
                                <p class="info-heading mb-0">
                                    <svg width="14" height="14" viewBox="0 0 25 24" fill="none" xmlns="http://www.w3.org/2000/svg" transform="rotate(0 0 0)">
    <path d="M14 9.85184C14 9.12691 13.4123 8.53924 12.6874 8.53924H12C11.1716 8.53924 10.5 9.21082 10.5 10.0392V10.3043C10.5 10.9296 10.8878 11.4892 11.4733 11.7088L13.0267 12.2914C13.6122 12.5109 14 13.0706 14 13.6959V13.9609C14 14.7894 13.3284 15.4609 12.5 15.4609H11.8126C11.0877 15.4609 10.5 14.8733 10.5 14.1483M12.25 15.4609V16.625M12.25 7.375V8.53924M3 12C3 17.1086 7.14137 21.25 12.25 21.25C17.3586 21.25 21.5 17.1086 21.5 12C21.5 6.89137 17.3586 2.75 12.25 2.75C7.14137 2.75 3 6.89137 3 12Z" stroke="#222222e8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>

    Extra charges
    </span>                                
                                </p>
                                <p class="card-text">None</p>
                            </div>
                        </div>
                        
                    </div>
                    <hr class="d-none my-3">

                    
                    <div class="d-flex justify-content-start gap-3">
                        

                        <% if(currUser) { %>    
                            <% const bookedIds = listing.bookedUsers.map(id => id.toString()); %>
                            <% const isBooked = bookedIds.includes(currUser._id.toString()); %>
                                <button 
                                    class="btn book-btn btn-secondary d-flex justify-content-center align-items-center gap-2 py-1"
                                    style="height: 50px; flex: 1; border-radius: 12px;"
                                    onclick="<%= !currUser ? `window.location.href='/login'` : `placeOrder('${listing._id}')` %>"
                                    <%= isBooked && "disabled" %>
                                >
                                    <p class="card-text mb-0">
                                        <% if(isBooked) { %>
                                            you already booked this
                                        <% } else { %>
                                            Book at &#8377; <%= listing.price.toLocaleString('en-IN') %> / night
                                            <i class="tax-info">&#8377; <%= listing.price + (18*listing.price/100)  %> (after tax)</i>
                                        <% } %>
                                    </p>
                                    <i class="fa-solid fa-arrow-right-long"></i>
                                </button>
                        <% } %>

                        <% if(currUser) { %>
                            <% const isSavedByUser = listing.isSaved.some(id => id.equals(currUser._id)); %>
                            
                            <button 
                            class="btn d-flex justify-content-center align-items-center gap-2 py-1 <%= isSavedByUser ? 'save-btn-filled' : 'save-btn-outline' %>" 
                            onclick="toggleSave(event, '<%= listing._id %>')">

                                <i class="fa-solid fa-bookmark" style="<%= isSavedByUser ? 'font-size: 13px;' : 'display:none;' %>"></i>
                                <i class="fa-regular fa-bookmark" style="<%= isSavedByUser ? 'display:none;' : 'font-size: 13px;' %>"></i>
                            </button>
                        <% } else { %>
                            <button 
                            class="btn save-btn-outline d-flex justify-content-center align-items-center gap-2 py-1" 
                            onclick="redirectToLogin(event)">
                                <i class="fa-regular fa-bookmark" style="font-size: 13px;"></i>
                            </button>
                        <% } %>


                    </div>
                </div>
            </div>
        </div>

    </div>

    <div>
        <div class="map-container position-relative" style="max-width: 998px; margin-inline: auto; margin-top: 4rem; padding-top: 0.8rem;">
            <h4 class="position-absolute" style="color: #373032; font-weight: 700; top: -10px; left: 0">Map Location</h4>
            <div id="map">
            </div>
        </div>
    </div>

    <div class="reviews-section" style="color: #212529ed; font-weight: 700;">
        <% if (currUser) { %>

            <h4 style="color: #373032; font-weight: 700;">Leave a Review</h4>
            
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation mb-3">
                <div class="mb-3 mt-4">
                    <label for="rating" class="form-label">Rating</label>
                    <fieldset class="starability-growRotate"> 
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>
                <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea style="border-radius: 10px;font-size: 13.5px; font-weight: 500; color: #212529e9;" name="review[comment]" id="comment" cols="30" rows="4" class="form-control" required></textarea>
                    <div class="invalid-feedback">Please add some comments!</div>
                </div>
                <button class="btn btn-dark mb-3 px-4 rounded-pill fw-semibold" style="font-size: 13px;">Submit</button>
            </form>

        <% } %>
        <% if (listing.reviews.length !== 0) { %>
        
            <h4 style="color: #373032; font-weight: 700; margin-block: 1.6rem;">
                All Reviews (<%= listing.reviews.length %>)
            </h4>

            <div id="reviewCarousel" class="carousel slide" data-bs-ride="carousel" >
                <div class="carousel-inner d-none d-lg-block">
                    <% for (let i = 0; i < listing.reviews.length; i += 2) { %>
                        <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                            <div class="row">
                                <% for (let j = i; j < i + 2 && j < listing.reviews.length; j++) { 
                                    let review = listing.reviews[j]; %>
                                    <div class="col-12 col-lg-6 mb-3">
                                        <div class="card h-full review-card">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between">
                                                <h5 class="card-title">
                                                    <b>@<%= review.author.username %></b>
                                                </h5>
                                                <% if (currUser && currUser._id.equals(review.author._id)) { %>
                                                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                                    <button class="btn btn-dark btn-sm del-btn">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </button>
                                                    </form>
                                                <% } %>
                                                </div>
                                                <div class="p-2">
                                                <p class="card-text mb-2"><%= review.comment %></p>
                                                <p class="starability-result card-text mb-0" data-rating="<%= review.rating %>"></p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>

                <div class="carousel-inner d-block d-lg-none">
                    <% listing.reviews.forEach((review, index) => { %>
                        <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                            <div class="card h-full review-card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                    <h5 class="card-title">
                                        <b>@<%= review.author.username %></b>
                                    </h5>
                                    <% if (currUser && currUser._id.equals(review.author._id)) { %>
                                        <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                        <button class="btn btn-dark btn-sm del-btn">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                        </form>
                                    <% } %>
                                    </div>
                                    <div class="p-2">
                                    <p class="card-text mb-2"><%= review.comment %></p>
                                    <p class="starability-result card-text mb-0" data-rating="<%= review.rating %>"></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <div class="carousel-controls text-center my-3">
                    <button class="carousel-control-prev custom-btn" type="button" data-bs-target="#reviewCarousel" data-bs-slide="prev">
                        <i class="fa-solid fa-angle-left" style="font-size: 12px;"></i>
                    </button>
                    <button class="carousel-control-next custom-btn" type="button" data-bs-target="#reviewCarousel" data-bs-slide="next">
                        <i class="fa-solid fa-angle-right" style="font-size: 12px;"></i>
                    </button>
                </div>
            </div>

        <% } %>
        <% if (listing.reviews.length === 0) { %>

            <h4 class="mb-5" style="color: #373032; font-weight: 700;">No Reviews</h4>
        
        <% } %>

    </div>


    <script>  
        const lon = "<%- JSON.stringify(listing.geometry.coordinates[1]) %>";
        const lat = "<%- JSON.stringify(listing.geometry.coordinates[0]) %>";
        const locationData = "<%- listing.location %>";
        const countryData = "<%- listing.country %>";

        let taxSwitch = document.getElementById("flexSwitchCheckDefault");
        if(taxSwitch) {
            taxSwitch.addEventListener("click", () => {
                let taxInfo =  document.getElementsByClassName("tax-info");
                for (info of taxInfo) {
                    if (info.style.display != "inline") {
                        info.style.display = "inline";
                    } else {
                        info.style.display = "none";
                    }
                }
            })
        };

        function toggleSave(e, listingId) {
            const btn = e.currentTarget;
            const solidIcon = btn.querySelector(".fa-solid");
            const regularIcon = btn.querySelector(".fa-regular");

            fetch(`/listings/${listingId}/toggle-save`, { method: "POST" })
                .then(res => res.json())
                .then(data => {
                    if (data.isSaved) {
                        btn.classList.remove("save-btn-outline");
                        btn.classList.add("save-btn-filled");

                        solidIcon.style.display = "inline";
                        regularIcon.style.display = "none";
                    } else {
                        btn.classList.remove("save-btn-filled");
                        btn.classList.add("save-btn-outline");

                        solidIcon.style.display = "none";
                        regularIcon.style.display = "inline";
                    }
                })
                .catch(err => console.error("Error toggling save:", err));
        };

        async function placeOrder(id) {
            try {

                const response = await fetch(`/payments/${id}/create-order`, {
                    method: "POST"
                });
                const order = await response.json();

                const options = {

                    key: "<%= razorpayKey %>",
                    amount: order.amount,
                    currency: order.currency,
                    name: "WanderLust",
                    description: "Booking Payment",
                    order_id: order.id,
                    handler: async function (response) {

                        const verifyResponse = await fetch(`/payments/${id}/verify-payment`, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify({
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_signature: response.razorpay_signature
                            })
                        });

                        const result = await verifyResponse.json();

                        console.log(result);

                    },
                    modal: {
                        ondismiss: async function () {
                        // user closed popup without paying
                        await fetch("/payments/mark-failed", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ order_id: order.id })
                        });
                        }
                    }
                };

                const razorpay = new Razorpay(options);
                razorpay.open();

            } catch (err) {
                console.log(err);
            }

        }

        function redirectToLogin(e) {
            e.preventDefault();
            e.stopPropagation();
            window.location.href = "/login";
        }

    </script>