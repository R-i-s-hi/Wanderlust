<% layout("/layouts/boilerplate") -%>

    <div class="d-flex justify-content-center">
        <div class="listing-single-card">
            <div class="d-flex flex-lg-row flex-column justify-content-start justify-content-lg-between gap-4 position-relative" style="padding-top: 3rem;">
                <div class="single-card-img-overlay">
                    <a href="/listings" class="home-link nav-link d-flex justify-content-start align-items-center gap-1 mb-1 mt-4 position-absolute">
                        <i class="fa-solid fa-angle-left"></i>
                        <span>
                            <i>Back to home</i>
                        </span>
                    </a>
                    <img src="<%= listing.image.url %>" class="single-card-img-top" alt="listing-image">
                </div>
                <div class="d-block justify-content-between align-items-between mt-2">
                    <div class="d-flex justify-content-between" style="margin-bottom: 2rem; gap: 1.5rem;">
                        <div>
                            <h3 class="mb-0" style="color: #373032; font-weight: 700;"><%= listing.title %></h3>
                            <p class="card-text" style="font-size: 10px;"><i> Owned by @<%= listing.owner.username %></i></p>
                        </div>
                        <div class=""> 
                            <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
                                <div class="btns">
                                    <a href="/listings/<%= listing._id %>/edit" class="btn edit-btn">
                                        <i class="fa-solid fa-highlighter"></i>
                                    </a>
                                    <div class="vr my-1"></div>
                                    <form class="delete-form" method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                                        <button class="btn del-btn">
                                            <i class="fa-regular fa-trash-can"></i>
                                        </button>
                                    </form>
                                </div>
                            <% } %>
                        </div>

                    </div>
                    
                    <div class="d-flex flex-column" style="gap: 1.8rem;">
