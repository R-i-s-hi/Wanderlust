<% layout("/layouts/boilerplate") -%>
<div class="d-flex justify-content-between align-items-center gap-5" style="padding-inline: 0.5rem; padding-top: 13px; margin-bottom: 4rem;">
    <div class="create-img-container">
        <a href="/listings" class="nav-link" style="margin-top: -75px;">
            <i class="fa-solid fa-arrow-left mt-1"></i>
        </a>
        <img class="createlisting-img" src="/images/createlisting_img.gif" style="min-width: 424px;" />
    </div>

    <div class="d-flex flex-column flex-fill gap-3">
        <div class="mt-4" style="color: #212529; font-weight: 700;">
            <h3 style="color: #373032; font-weight: 700;">Add Your Property</h3><br>
            <form method="POST" action="/listings" novalidate class="needs-validation create-form" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" class="form-control" name="listing[title]" id="title" required>
                    <div class="valid-feedback">Title looks good!</div>
                    <div class="invalid-feedback">Title looks bad!</div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" name="listing[description]" id="description" required></textarea>
                    <div class="invalid-feedback">Please enter a description!</div>
                </div>
                <div class="mb-3">
                    <label for="url" class="form-label">Upload Image</label>
                    <input style="font-size: small; color: #212529b3;" class="form-control fw-medium" type="file" name="listing[image]" id="url" required>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input class="form-control" type="number" name="listing[price]" id="price" required>
                        <div class="invalid-feedback">Price should be valid!</div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input class="form-control" type="text" name="listing[country]" id="country" required>
                        <div class="invalid-feedback">Country name should be valid!</div>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input class="form-control" type="text" name="listing[location]" id="location" required>
                    <div class="invalid-feedback">Location should be valid!</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Amenities</label>
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary rounded-pill fw-semibold dropdown-toggle" type="button" style="font-size: 13px;" data-bs-toggle="dropdown">
                            Select Amenities
                        </button>
                        <ul class="dropdown-menu rounded-4 p-3" style="min-width: 250px;">
                        <li>
                            <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="amenities" value="WiFi" id="wifiDropdown">
                            <label class="form-check-label" for="wifiDropdown">WiFi</label>
                            </div>
                        </li>
                        <li>
                            <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="amenities" value="Swimming Pool" id="poolDropdown">
                            <label class="form-check-label" for="poolDropdown">Swimming Pool</label>
                            </div>
                        </li>
                        <li>
                            <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="amenities" value="Mountains & Hills" id="Mountain&HillsDropdown">
                            <label class="form-check-label" for="Mountain&HillsDropdown">Mountains & Hills</label>
                            </div>
                        </li>
                        <li>
                            <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="amenities" value="Air Conditioning" id="ACDropdown">
                            <label class="form-check-label" for="ACDropdown">Air Conditioning</label>
                            </div>
                        </li>
                        <li>
                            <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="amenities" value="Beach & Tent" id="B&TDropdown">
                            <label class="form-check-label" for="B&TDropdown">Beach & Tent</label>
                            </div>
                        </li>
                        <li>
                            <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="amenities" value="Lake & Rivers" id="L&RDropdown">
                            <label class="form-check-label" for="L&RDropdown">Lake & Rivers</label>
                            </div>
                        </li>
                        <li>
                            <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="amenities" value="Boat house" id="BHDropdown">
                            <label class="form-check-label" for="BHDropdown">Boat house</label>
                            </div>
                        </li>
                        </ul>
                    </div>
                </div>

                <div class="create-form-btns d-flex justify-content-start gap-3">
                    <button class="btn btn-dark mb-3 add-btn">Add property</button>
                    <a class="btn btn-outline-secondary" href="/listings">Go back</a>
                </div>

            </form>
        </div>
    </div>
</div>