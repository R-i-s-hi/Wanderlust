<% layout("/layouts/boilerplate") -%>
<div class="d-flex justify-content-between align-items-center gap-5">
    <div>
        <a href="/listings" class="nav-link" style="margin-top: -60px;">
            <i class="fa-solid fa-arrow-left mt-1"></i>
        </a>
        <img class="createlisting-img" src="/images/createlisting_img.gif" style="min-width: 424px;" />
    </div>

    <div class="d-flex flex-column flex-fill gap-3">
        <div class="mt-4" style="color: #212529; font-weight: 700;">
            <div class="d-flex align-items-center justify-comtent-center">
                <a href="/listings" class="nav-link">
                    <i class="fa-solid fa-arrow-left mt-1"></i>
                </a>
                <h3 style="color: #373032; font-weight: 700;">Add Your Property</h3><br>
            </div>
            <form method="POST" action="/listings" novalidate class="needs-validation create-form" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" class="form-control" name="listing[title]" id="title" required>
                    <div class="valid-feedback">Title looks good!</div>
                    <div class="invalid-feedback">Title looks bad!</div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" name="listing[description]" id="description" required></textarea>
                    <div class="invalid-feedback">Please enter a description!</div>
                </div>
                <div class="mb-3">
                    <label for="url" class="form-label">Upload Image</label>
                    <input style="font-size: small; color: #212529b3;" class="form-control fw-medium" type="file" name="listing[image]" id="url" required>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input class="form-control" type="number" name="listing[price]" id="price" required>
                        <div class="invalid-feedback">Price should be valid!</div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input class="form-control" type="text" name="listing[country]" id="country" required>
                        <div class="invalid-feedback">Country name should be valid!</div>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input class="form-control" type="text" name="listing[location]" id="location" required>
                    <div class="invalid-feedback">Location should be valid!</div>
                </div>
                <div class="create-form-btns d-block d-sm-flex justify-content-start gap-3">
                    <button class="btn btn-dark mb-3 add-btn">Add listing</button>
                </div>
            </form>
        </div>
    </div>
</div>